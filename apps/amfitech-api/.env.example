# Copy this file to apps/amfitech-api/.env and fill in real values.
# .env is gitignored — never commit secrets.

# ---- Server ----
PORT=3000

# Comma-separated origins allowed by CORS
FRONTEND_ORIGINS=http://localhost:4200,http://localhost:4201

# ---- AdminPulse upstream ----
ADMIN_PULSE_BASE_URL=https://api.adminpulse.be
ADMIN_PULSE_TIMEOUT_MS=30000

# ---- Cache ----
# 5 minutes default for slow-changing AdminPulse reads
CACHE_TTL_MS=300000

# ---- Supabase ----
SUPABASE_URL=https://gvwjmrfsbnwyhagectdx.supabase.co
SUPABASE_ANON_KEY=<paste anon key here>
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key here>

# ---- API-key encryption ----
# Generate once with: openssl rand -hex 32
# Must be exactly 64 hex chars (32 bytes). If you lose it, every stored
# AdminPulse API key becomes unrecoverable — back it up to a password manager.
ENCRYPTION_KEY=<paste 64-char hex key here>
